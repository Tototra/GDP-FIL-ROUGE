# Researcher, Team, Publication, Venue, Topic, Year
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix lre: <http://example.com/lre#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

lre:Researcher a owl:Class;
    rdfs:subClassOf foaf:Person .
lre:Publication a owl:Class .
lre:Team a owl:Class .
lre:Venue a owl:Class .
lre:Topic a owl:Class .
lre:Year a owl:Class .

lre:memberOf a owl:ObjectProperty;
    rdfs:domain lre:Researcher;
    rdfs:range lre:Team .

lre:authoredBy a owl:ObjectProperty;
    rdfs:domain lre:Publication;
    rdfs:range lre:Researcher .

lre:coAuthorOf a owl:ObjectProperty;
    rdfs:domain lre:Researcher;
    rdfs:range lre:Researcher .

lre:pusblishedIn a owl:ObjectProperty;
    rdfs:domain lre:Publication;
    rdfs:range lre:Venue .

lre:inYear a owl:ObjectProperty;
    rdfs:domain lre:Publication;
    rdfs:range lre:Year .

lre:dblpPage a owl:ObjectProperty;
    rdfs:domain lre:Researcher ;
    rdfs:range rdfs:Resource .

# Utilisé pour Researcher et Publication
lre:hasTopic a owl:ObjectProperty;
    rdfs:range lre:Topic .

lre:arrivalYear a owl:DatatypeProperty;
    rdfs:domain lre:Researcher;
    rdfs:range xsd:gYear .

dcterms:title a owl:DatatypeProperty;
    rdfs:range xsd:string .

foaf:name a owl:DatatypeProperty;
    rdfs:domain lre:Researcher;
    rdfs:range xsd:string

lre:source a owl:DatatypeProperty ;
    rdfs:domain lre:Venue ;
    rdfs:range  xsd:string .

lre:url a owl:DatatypeProperty ;
    rdfs:domain lre:Publication ;
    rdfs:range xsd:string .
